---
import QRCodeModal from './QRCodeModal.astro';

interface Review {
  reviewer: string;
  date: string;
  rating: number;
  text: string;
}

interface Props {
  googleRating?: number;
  googleReviewCount?: number;
  googleReviews?: Review[];
  googleUrl?: string;
  tripadvisorRating?: number;
  tripadvisorReviewCount?: number;
  tripadvisorReviews?: Review[];
  tripadvisorUrl?: string;
}

const {
  googleRating,
  googleReviewCount,
  googleReviews,
  googleUrl,
  tripadvisorRating,
  tripadvisorReviewCount,
  tripadvisorReviews,
  tripadvisorUrl,
} = Astro.props;

function formatDate(dateString: string) {
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

function getInitials(name: string): string {
  return name.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase();
}

// Determine what data we actually have
const hasGoogleReviews = !!(googleReviews && googleReviews.length > 0);
const hasGoogleRating = !!(googleRating && googleRating > 0 && googleReviewCount && googleReviewCount > 0);
const hasGoogle = hasGoogleReviews || hasGoogleRating;
const hasTripAdvisor = !!(tripadvisorUrl && tripadvisorReviews && tripadvisorReviews.length > 0);

// Which tab is active by default
const googleActive = hasGoogle;
const tripadvisorActive = !hasGoogle && hasTripAdvisor;

// Whether we have real URLs for the link/QR buttons
const hasGoogleUrl = !!(googleUrl && googleUrl !== '#');
const hasTripAdvisorUrl = !!(tripadvisorUrl && tripadvisorUrl !== '#');

const activeTabClasses = 'text-[#171795] border-[#171795] bg-[#171795]/[0.02]';
const inactiveTabClasses = 'text-slate-500 border-transparent hover:text-slate-700 hover:bg-slate-50';
---

{hasGoogle || hasTripAdvisor ? (
  <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
    <!-- Tabs -->
    <div class="flex border-b border-slate-100">
      {hasGoogle && (
        <button
          type="button"
          class={`review-tab flex-1 px-4 py-4 text-sm font-bold border-b-2 transition-all duration-200 ${googleActive ? activeTabClasses : inactiveTabClasses}`}
          data-tab="google"
        >
          <span class="flex items-center justify-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Google
          </span>
        </button>
      )}
      {hasTripAdvisor && (
        <button
          type="button"
          class={`review-tab flex-1 px-4 py-4 text-sm font-bold border-b-2 transition-all duration-200 ${tripadvisorActive ? activeTabClasses : inactiveTabClasses}`}
          data-tab="tripadvisor"
        >
          <span class="flex items-center justify-center gap-2">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12.006 4.295c-2.67 0-5.338.784-7.645 2.353H0l1.963 2.135a5.997 5.997 0 0 0 4.04 10.43 5.976 5.976 0 0 0 4.075-1.6L12 19.705l1.922-2.09a5.972 5.972 0 0 0 4.072 1.598 6 6 0 0 0 6-5.998 5.982 5.982 0 0 0-1.957-4.432L24 6.648h-4.35a13.573 13.573 0 0 0-7.644-2.353zM12 6.255c1.531 0 3.063.303 4.504.903C13.943 8.138 12 10.43 12 13.1c0-2.671-1.942-4.962-4.504-5.942A11.72 11.72 0 0 1 12 6.256zM6.002 9.157a4.059 4.059 0 1 1 0 8.118 4.059 4.059 0 0 1 0-8.118zm11.992.002a4.057 4.057 0 1 1 .003 8.115 4.057 4.057 0 0 1-.003-8.115zm-11.992 1.93a2.128 2.128 0 0 0 0 4.256 2.128 2.128 0 0 0 0-4.256zm11.992 0a2.128 2.128 0 0 0 0 4.256 2.128 2.128 0 0 0 0-4.256z"/>
            </svg>
            TripAdvisor
          </span>
        </button>
      )}
    </div>

    <!-- Google Panel -->
    {hasGoogle && (
      <div class={`review-panel p-6 sm:p-7 ${googleActive ? '' : 'hidden'}`} data-panel="google">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h3 class="text-lg font-bold text-slate-900">Google Reviews</h3>
            <p class="text-sm text-slate-500">Verified customer reviews</p>
          </div>
          {hasGoogleRating && (
            <div class="flex items-center gap-2">
              <span class="text-2xl font-extrabold text-slate-900">{googleRating}</span>
              <div class="flex flex-col">
                <div class="flex">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <svg class={`w-3.5 h-3.5 ${i < Math.round(googleRating || 0) ? 'text-amber-400' : 'text-slate-200'}`} fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  ))}
                </div>
                <span class="text-xs text-slate-400 font-medium">({googleReviewCount})</span>
              </div>
            </div>
          )}
        </div>

        {hasGoogleReviews ? (
          <div class="space-y-5">
            {googleReviews!.map((review) => (
              <div class="border-b border-slate-100 last:border-0 last:pb-0 pb-5">
                <div class="flex items-start gap-3 mb-2">
                  <div class="w-9 h-9 rounded-full bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center shrink-0 border border-slate-100">
                    <span class="text-xs font-bold text-slate-600">{getInitials(review.reviewer)}</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 flex-wrap">
                      <span class="text-sm font-bold text-slate-900">{review.reviewer}</span>
                      <span class="text-xs text-slate-400 font-medium">{formatDate(review.date)}</span>
                    </div>
                    <div class="flex gap-0.5 mt-1">
                      {Array.from({ length: 5 }).map((_, i) => (
                        <svg class={`w-3 h-3 ${i < review.rating ? 'text-amber-400' : 'text-slate-200'}`} fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                        </svg>
                      ))}
                    </div>
                  </div>
                </div>
                <p class="text-sm text-slate-600 leading-relaxed">{review.text}</p>
              </div>
            ))}
          </div>
        ) : (
          <p class="text-sm text-slate-400 text-center py-8">No individual reviews to display. Visit Google for the full list.</p>
        )}

        {(hasGoogleUrl || hasGoogleReviews) && (
          <div class="mt-6 pt-5 border-t border-slate-100 flex flex-col sm:flex-row gap-3">
            {hasGoogleUrl && (
              <a
                href={googleUrl}
                target="_blank"
                rel="nofollow noopener"
                class="inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold bg-[#171795] text-white hover:bg-[#0f0f5a] transition-colors"
              >
                Visit Google Profile
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            )}
            {hasGoogleUrl && <QRCodeModal url={googleUrl} label="Get QR Code" />}
          </div>
        )}
      </div>
    )}

    <!-- TripAdvisor Panel -->
    {hasTripAdvisor && (
      <div class={`review-panel p-6 sm:p-7 ${tripadvisorActive ? '' : 'hidden'}`} data-panel="tripadvisor">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h3 class="text-lg font-bold text-slate-900">TripAdvisor Reviews</h3>
            <p class="text-sm text-slate-500">Traveler reviews and ratings</p>
          </div>
          {tripadvisorRating && tripadvisorRating > 0 && (
            <div class="flex items-center gap-2">
              <span class="text-2xl font-extrabold text-slate-900">{tripadvisorRating}</span>
              <div class="flex flex-col">
                <div class="flex">
                  {Array.from({ length: 5 }).map((_, i) => (
                    <svg class={`w-3.5 h-3.5 ${i < Math.round(tripadvisorRating) ? 'text-amber-400' : 'text-slate-200'}`} fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  ))}
                </div>
                {tripadvisorReviewCount && tripadvisorReviewCount > 0 && (
                  <span class="text-xs text-slate-400 font-medium">({tripadvisorReviewCount})</span>
                )}
              </div>
            </div>
          )}
        </div>

        <div class="space-y-5">
          {tripadvisorReviews!.map((review) => (
            <div class="border-b border-slate-100 last:border-0 last:pb-0 pb-5">
              <div class="flex items-start gap-3 mb-2">
                <div class="w-9 h-9 rounded-full bg-gradient-to-br from-emerald-50 to-emerald-100 flex items-center justify-center shrink-0 border border-emerald-100">
                  <span class="text-xs font-bold text-emerald-700">{getInitials(review.reviewer)}</span>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-sm font-bold text-slate-900">{review.reviewer}</span>
                    <span class="text-xs text-slate-400 font-medium">{formatDate(review.date)}</span>
                  </div>
                  <div class="flex gap-0.5 mt-1">
                    {Array.from({ length: 5 }).map((_, i) => (
                      <svg class={`w-3 h-3 ${i < review.rating ? 'text-amber-400' : 'text-slate-200'}`} fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                      </svg>
                    ))}
                  </div>
                </div>
              </div>
              <p class="text-sm text-slate-600 leading-relaxed">{review.text}</p>
            </div>
          ))}
        </div>

        {hasTripAdvisorUrl && (
          <div class="mt-6 pt-5 border-t border-slate-100 flex flex-col sm:flex-row gap-3">
            <a
              href={tripadvisorUrl}
              target="_blank"
              rel="nofollow noopener"
              class="inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold bg-[#171795] text-white hover:bg-[#0f0f5a] transition-colors"
            >
              Visit TripAdvisor
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
            <QRCodeModal url={tripadvisorUrl} label="Get QR Code" />
          </div>
        )}
      </div>
    )}
  </div>
) : null}

<script>
  const tabGroups = document.querySelectorAll('.review-tab');
  const panels = document.querySelectorAll('.review-panel');

  tabGroups.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      if (!target) return;

      tabGroups.forEach(t => {
        if (t.dataset.tab === target) {
          t.classList.add('text-[#171795]', 'border-[#171795]', 'bg-[#171795]/[0.02]');
          t.classList.remove('text-slate-500', 'border-transparent', 'hover:text-slate-700', 'hover:bg-slate-50');
        } else {
          t.classList.remove('text-[#171795]', 'border-[#171795]', 'bg-[#171795]/[0.02]');
          t.classList.add('text-slate-500', 'border-transparent', 'hover:text-slate-700', 'hover:bg-slate-50');
        }
      });

      panels.forEach(p => {
        if (p.dataset.panel === target) {
          p.classList.remove('hidden');
        } else {
          p.classList.add('hidden');
        }
      });
    });
  });
</script>
