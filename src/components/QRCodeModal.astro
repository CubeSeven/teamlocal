---
interface Props {
  url: string;
  label?: string;
}

const { url, label = "View QR Code" } = Astro.props;
---

<div data-qr-wrapper>
<button
  type="button"
  data-qr-trigger
  data-qr-url={url}
  class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold border border-slate-200 text-slate-700 bg-white hover:bg-slate-50 hover:border-slate-300 transition-all duration-200"
>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"/>
  </svg>
  {label}
</button>

<!-- Modal -->
<div
  data-qr-modal
  class="fixed inset-0 z-50 hidden items-center justify-center p-4"
  aria-hidden="true"
>
  <div data-qr-backdrop class="absolute inset-0 bg-black/40 backdrop-blur-sm transition-opacity opacity-0"></div>
  <div data-qr-panel class="relative bg-white rounded-2xl shadow-2xl max-w-sm w-full p-6 transform scale-95 opacity-0 transition-all duration-200">
    <div class="flex items-center justify-between mb-5">
      <div>
        <h3 class="text-lg font-bold text-slate-900">Review QR Code</h3>
        <p class="text-xs text-slate-500 mt-0.5">Scan to open the review page</p>
      </div>
      <button type="button" data-qr-close class="p-2 rounded-lg hover:bg-slate-100 transition-colors">
        <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div class="flex flex-col items-center">
      <div class="p-4 bg-white rounded-xl border border-slate-100 shadow-inner">
        <canvas data-qr-canvas class="w-48 h-48"></canvas>
      </div>
      <p class="mt-3 text-xs text-slate-400 text-center line-clamp-1 max-w-[240px]">{url}</p>
    </div>

    <div class="mt-6 flex gap-3">
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold bg-slate-100 text-slate-700 hover:bg-slate-200 transition-colors"
      >
        Open Link
      </a>
      <button
        type="button"
        data-qr-download
        class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold bg-[#171795] text-white hover:bg-[#0f0f5a] transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Download
      </button>
    </div>
  </div>
</div>
</div>

<script>
  import QRCode from 'qrcode';

  const wrappers = document.querySelectorAll('[data-qr-wrapper]');

  for (const wrapper of wrappers) {
    const btn = wrapper.querySelector('[data-qr-trigger]');
    const modal = wrapper.querySelector('[data-qr-modal]');
    const canvas = wrapper.querySelector('[data-qr-canvas]');
    const backdrop = wrapper.querySelector('[data-qr-backdrop]');
    const panel = wrapper.querySelector('[data-qr-panel]');
    const closeBtn = wrapper.querySelector('[data-qr-close]');
    const downloadBtn = wrapper.querySelector('[data-qr-download]');
    const url = btn?.getAttribute('data-qr-url');

  let generated = false;

  function openModal() {
    if (!modal || !canvas) return;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';

    requestAnimationFrame(() => {
      backdrop?.classList.remove('opacity-0');
      panel?.classList.remove('scale-95', 'opacity-0');
      panel?.classList.add('scale-100', 'opacity-100');
    });

    if (!generated && url) {
      QRCode.toCanvas(canvas, url, {
        width: 192,
        margin: 2,
        color: {
          dark: '#171795',
          light: '#ffffff'
        }
      });
      generated = true;
    }
  }

  function closeModal() {
    if (!modal) return;
    backdrop?.classList.add('opacity-0');
    panel?.classList.remove('scale-100', 'opacity-100');
    panel?.classList.add('scale-95', 'opacity-0');

    setTimeout(() => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    }, 200);
  }

  function downloadQR() {
    if (!canvas) return;
    const link = document.createElement('a');
    link.download = 'review-qr-code.png';
    link.href = canvas.toDataURL('image/png');
    link.click();
  }

    btn?.addEventListener('click', openModal);
    closeBtn?.addEventListener('click', closeModal);
    backdrop?.addEventListener('click', closeModal);
    downloadBtn?.addEventListener('click', downloadQR);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal?.classList.contains('hidden')) {
        closeModal();
      }
    });
  }
</script>
