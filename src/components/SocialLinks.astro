---
interface Props {
  social?: {
    facebook?: string;
    instagram?: string;
    website?: string;
    tripadvisor?: string;
  };
}

const { social } = Astro.props;
---

{social && (social.website || social.facebook || social.instagram || social.tripadvisor) && (
  <div class="bg-white rounded-2xl border border-slate-100 p-6 sm:p-7 shadow-sm">
    <h3 class="text-lg font-bold text-slate-900 mb-4">Follow & Visit</h3>
    <div class="flex flex-wrap items-center gap-2.5">
      {social.website && (
        <a
          href={social.website}
          target="_blank"
          rel="noopener"
          class="w-11 h-11 rounded-xl bg-slate-50 hover:bg-[#171795]/10 border border-slate-100 hover:border-[#171795]/20 flex items-center justify-center transition-all duration-200 group"
          title="Website"
          aria-label="Visit website"
        >
          <svg class="w-5 h-5 text-slate-500 group-hover:text-[#171795] transition-colors" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10" />
            <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" />
            <path d="M2 12h20" />
          </svg>
        </a>
      )}

      {social.facebook && (
        <a
          href={social.facebook}
          target="_blank"
          rel="nofollow noopener"
          class="w-11 h-11 rounded-xl bg-slate-50 hover:bg-[#171795]/10 border border-slate-100 hover:border-[#171795]/20 flex items-center justify-center transition-all duration-200 group"
          title="Facebook"
          aria-label="Visit Facebook profile"
        >
          <svg class="w-5 h-5 text-slate-500 group-hover:text-[#171795] transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      )}

      {social.instagram && (
        <a
          href={social.instagram}
          target="_blank"
          rel="nofollow noopener"
          class="w-11 h-11 rounded-xl bg-slate-50 hover:bg-[#171795]/10 border border-slate-100 hover:border-[#171795]/20 flex items-center justify-center transition-all duration-200 group"
          title="Instagram"
          aria-label="Visit Instagram profile"
        >
          <svg class="w-5 h-5 text-slate-500 group-hover:text-[#171795] transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
      )}

      {social.tripadvisor && (
        <a
          href={social.tripadvisor}
          target="_blank"
          rel="nofollow noopener"
          class="w-11 h-11 rounded-xl bg-slate-50 hover:bg-[#171795]/10 border border-slate-100 hover:border-[#171795]/20 flex items-center justify-center transition-all duration-200 group"
          title="TripAdvisor"
          aria-label="Visit TripAdvisor profile"
        >
          <svg class="w-5 h-5 text-slate-500 group-hover:text-[#171795] transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12.006 4.295c-2.67 0-5.338.784-7.645 2.353H0l1.963 2.135a5.997 5.997 0 0 0 4.04 10.43 5.976 5.976 0 0 0 4.075-1.6L12 19.705l1.922-2.09a5.972 5.972 0 0 0 4.072 1.598 6 6 0 0 0 6-5.998 5.982 5.982 0 0 0-1.957-4.432L24 6.648h-4.35a13.573 13.573 0 0 0-7.644-2.353zM12 6.255c1.531 0 3.063.303 4.504.903C13.943 8.138 12 10.43 12 13.1c0-2.671-1.942-4.962-4.504-5.942A11.72 11.72 0 0 1 12 6.256zM6.002 9.157a4.059 4.059 0 1 1 0 8.118 4.059 4.059 0 0 1 0-8.118zm11.992.002a4.057 4.057 0 1 1 .003 8.115 4.057 4.057 0 0 1-.003-8.115zm-11.992 1.93a2.128 2.128 0 0 0 0 4.256 2.128 2.128 0 0 0 0-4.256zm11.992 0a2.128 2.128 0 0 0 0 4.256 2.128 2.128 0 0 0 0-4.256z"/>
          </svg>
        </a>
      )}
    </div>
  </div>
)}
