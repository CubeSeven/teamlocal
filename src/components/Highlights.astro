---
interface Props {
  highlights?: string[];
}

const { highlights } = Astro.props;
---

{highlights && highlights.length > 0 && (
  <div class="bg-white rounded-2xl border border-slate-100 p-6 sm:p-7 shadow-sm">
    <h3 class="text-lg font-bold text-slate-900 mb-5">Highlights</h3>
    <ul class="space-y-3.5">
      {highlights.map((highlight) => (
        <li class="flex items-start gap-3">
          <div class="w-5 h-5 rounded-full bg-[#171795]/10 flex items-center justify-center shrink-0 mt-0.5">
            <svg class="w-3 h-3 text-[#171795]" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
          </div>
          <span class="text-sm sm:text-base text-slate-600 leading-relaxed">{highlight}</span>
        </li>
      ))}
    </ul>
  </div>
)}
