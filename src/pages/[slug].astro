---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BusinessHero from '../components/BusinessHero.astro';
import Highlights from '../components/Highlights.astro';
import ReviewsTabs from '../components/ReviewsTabs.astro';
import ContactDetails from '../components/ContactDetails.astro';
import SocialLinks from '../components/SocialLinks.astro';
import Map from '../components/Map.astro';
import SEOLocalBusiness from '../components/SEOLocalBusiness.astro';
import SEOBreadcrumb from '../components/SEOBreadcrumb.astro';
import MarkdownIt from 'markdown-it';

export async function getStaticPaths() {
  const businesses = await getCollection('businesses');
  return businesses.map(business => ({
    params: { slug: business.data.slug },
    props: { business },
  }));
}

const { business } = Astro.props;
const { data } = business;

const md = new MarkdownIt({ html: true, linkify: true });
const bodyHtml = business.body ? md.render(business.body) : '';

function deriveMetaDescription(text: string, maxLen = 160): string {
  if (text.length <= maxLen) return text;
  const truncated = text.substring(0, maxLen);
  const lastSpace = truncated.lastIndexOf(' ');
  return truncated.substring(0, lastSpace > 0 ? lastSpace : maxLen) + '...';
}

const metaDescription = deriveMetaDescription(data.description);
const pageTitle = `${data.name} — Skiathos Atletico Sponsor`;

// Determine which quick actions to show in the sticky bar
const hasPhone = !!(data.contact?.phone);
const hasCoords = data.latitude !== undefined && data.longitude !== undefined;
const hasWebsite = !!(data.social?.website);
const directionsUrl = hasCoords 
  ? `https://www.google.com/maps/dir/?api=1&destination=${data.latitude},${data.longitude}`
  : (data.contact?.address 
    ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(data.contact.address + ', Skiathos, Greece')}`
    : null);
const quickActionCount = [hasPhone, !!directionsUrl, hasWebsite].filter(Boolean).length;
---

<BaseLayout 
  title={pageTitle}
  description={metaDescription}
  image={data.featuredImage}
  canonicalUrl={`/${data.slug}/`}
>
  <SEOLocalBusiness 
    name={data.name}
    description={data.description}
    image={data.featuredImage}
    logo={data.logo}
    category={data.category}
    slug={data.slug}
    contact={data.contact}
    social={data.social}
    googleRating={data.googleRating}
    googleReviewCount={data.googleReviewCount}
    reviews={data.reviews}
    latitude={data.latitude}
    longitude={data.longitude}
    openingHours={data.openingHours}
    priceRange={data.priceRange}
    servesCuisine={data.servesCuisine}
  />
  <SEOBreadcrumb 
    name={data.name}
    category={data.category}
    subCategory={data.subCategory}
    slug={data.slug}
  />
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8 lg:py-10 pb-24 lg:pb-10">
    <!-- Back Button (bigger touch target) -->
    <a 
      href="/" 
      class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-[#171795] transition-colors duration-200 mb-5 sm:mb-6 group py-2 -ml-2 px-2 rounded-lg hover:bg-slate-50"
    >
      <svg class="w-4 h-4 transition-transform duration-200 group-hover:-translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to directory
    </a>

    <!-- Hero -->
    <BusinessHero business={business} />

    <div class="mt-24 sm:mt-28 lg:mt-28 grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-2 space-y-6">
        <!-- Description with Read More -->
        <div class="bg-white rounded-2xl border border-slate-100 p-5 sm:p-6 lg:p-7 shadow-sm">
          <h2 class="text-xl sm:text-2xl font-bold text-slate-900 mb-4">About {data.name}</h2>
          <p class="text-slate-600 leading-relaxed text-base mb-4">{data.description}</p>
          {bodyHtml && (
            <div id="description-container" class="description-collapsed text-slate-600 leading-relaxed text-base space-y-4 prose-headings:text-slate-900 prose-a:text-[#171795] prose-strong:text-slate-800 max-w-none" set:html={bodyHtml} />
          )}
          {bodyHtml && (
            <button
              id="read-more-btn"
              class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[#171795] hover:text-[#0f0f5a] transition-colors"
            >
              <span id="read-more-text">Read more</span>
              <svg id="read-more-icon" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
          )}
        </div>

        <!-- Highlights -->
        {data.highlights && data.highlights.length > 0 && (
          <Highlights highlights={data.highlights} />
        )}

        <!-- Reviews Tabs -->
        {((data.reviews && data.reviews.length > 0) || (data.tripadvisorReviews && data.tripadvisorReviews.length > 0)) && (
          <ReviewsTabs 
            googleRating={data.googleRating}
            googleReviewCount={data.googleReviewCount}
            googleReviews={data.reviews}
            googleUrl={data.googleUrl || data.social?.google}
            tripadvisorRating={data.tripadvisorRating}
            tripadvisorReviewCount={data.tripadvisorReviewCount}
            tripadvisorReviews={data.tripadvisorReviews}
            tripadvisorUrl={data.social?.tripadvisor}
          />
        )}
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <ContactDetails contact={data.contact} />
        <SocialLinks social={data.social} />
        
        <!-- Map (isolation isolates Leaflet's internal z-indexes) -->
        <div class="bg-white rounded-2xl border border-slate-100 p-5 sm:p-6 lg:p-7 shadow-sm isolate relative z-0">
          <h3 class="text-lg font-bold text-slate-900 mb-4">Location</h3>
          {hasCoords ? (
            <Fragment>
              <Map lat={data.latitude!} lng={data.longitude!} zoom={14} />
              <p class="text-xs text-slate-400 mt-3">{data.contact?.address || 'Skiathos'}</p>
            </Fragment>
          ) : (
            <div class="w-full h-80 rounded-2xl border border-slate-100 bg-slate-50 flex flex-col items-center justify-center text-slate-400">
              <svg class="w-10 h-10 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <p class="text-sm font-medium">Location not yet provided</p>
              <p class="text-xs mt-1">Check contact details above</p>
            </div>
          )}
        </div>
        
        <!-- CTA -->
        <div class="bg-gradient-to-br from-[#171795] to-[#0f0f5a] rounded-2xl p-5 sm:p-6 lg:p-7 text-white shadow-lg shadow-[#171795]/20">
          <div class="w-10 h-10 rounded-xl bg-white/15 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2">Support Skiathos Atletico</h3>
          <p class="text-sm text-white/75 leading-relaxed mb-5">
            This business proudly sponsors our football team. Your support helps them continue their partnership!
          </p>
          <a 
            href="/" 
            class="inline-flex items-center justify-center w-full gap-2 bg-white text-[#171795] px-4 py-2.5 rounded-xl text-sm font-bold hover:bg-slate-50 transition-colors"
          >
            Visit our Directory
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile sticky bottom action bar -->
  {quickActionCount > 0 && (
    <div class="lg:hidden fixed bottom-0 inset-x-0 z-50 bg-white border-t border-slate-200 shadow-[0_-4px_20px_-4px_rgba(0,0,0,0.1)] pb-[env(safe-area-inset-bottom)]">
      <div class="flex items-stretch">
        {hasPhone && (
          <a
            href={`tel:${data.contact?.phone}`}
            class="flex-1 flex flex-col items-center justify-center gap-1 py-3 text-[#171795] hover:bg-[#171795]/5 transition-colors min-h-[60px]"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span class="text-xs font-semibold">Call</span>
          </a>
        )}
        {directionsUrl && (
          <a
            href={directionsUrl}
            target="_blank"
            rel="noopener"
            class="flex-1 flex flex-col items-center justify-center gap-1 py-3 text-[#171795] hover:bg-[#171795]/5 transition-colors min-h-[60px] border-l border-slate-100"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
            </svg>
            <span class="text-xs font-semibold">Directions</span>
          </a>
        )}
        {hasWebsite && (
          <a
            href={data.social?.website}
            target="_blank"
            rel="noopener"
            class="flex-1 flex flex-col items-center justify-center gap-1 py-3 text-[#171795] hover:bg-[#171795]/5 transition-colors min-h-[60px] border-l border-slate-100"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" />
              <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" />
              <path d="M2 12h20" />
            </svg>
            <span class="text-xs font-semibold">Website</span>
          </a>
        )}
      </div>
    </div>
  )}

  <!-- Read More / Description toggle script -->
  <script>
    const descContainer = document.getElementById('description-container');
    const readMoreBtn = document.getElementById('read-more-btn');
    const readMoreText = document.getElementById('read-more-text');
    const readMoreIcon = document.getElementById('read-more-icon');

    if (descContainer && readMoreBtn) {
      // Check if content is long enough to need truncation
      const contentHeight = descContainer.scrollHeight;
      const collapsedHeight = 200;

      if (contentHeight <= collapsedHeight) {
        // Content is short, no need for Read More
        descContainer.classList.remove('description-collapsed');
        readMoreBtn.style.display = 'none';
      } else {
        readMoreBtn.addEventListener('click', () => {
          const isCollapsed = descContainer.classList.contains('description-collapsed');
          if (isCollapsed) {
            descContainer.classList.remove('description-collapsed');
            descContainer.classList.add('description-expanded');
            if (readMoreText) readMoreText.textContent = 'Show less';
            if (readMoreIcon) readMoreIcon.style.transform = 'rotate(180deg)';
          } else {
            descContainer.classList.add('description-collapsed');
            descContainer.classList.remove('description-expanded');
            if (readMoreText) readMoreText.textContent = 'Read more';
            if (readMoreIcon) readMoreIcon.style.transform = 'rotate(0deg)';
          }
        });
      }
    }
  </script>

  <style is:global>
    .description-collapsed {
      max-height: 200px;
      overflow: hidden;
      position: relative;
    }
    .description-collapsed::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 60px;
      background: linear-gradient(to bottom, transparent, white);
      pointer-events: none;
    }
    .description-expanded {
      max-height: none;
    }
  </style>
</BaseLayout>
