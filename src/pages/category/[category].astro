---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BusinessCard from '../../components/BusinessCard.astro';

export async function getStaticPaths() {
  const businesses = await getCollection('businesses');
  const slugs = new Set<string>();

  function slugify(text: string): string {
    return text.toLowerCase().replace(/\s+/g, '-');
  }

  for (const b of businesses) {
    slugs.add(slugify(b.data.category));
    if (b.data.subCategory) {
      slugs.add(slugify(b.data.subCategory));
    }
  }

  return [...slugs].map((slug) => ({ params: { category: slug } }));
}

function slugify(text: string): string {
  return text.toLowerCase().replace(/\s+/g, '-');
}

const { category } = Astro.params;
const businesses = await getCollection('businesses');

const matches: typeof businesses = [];
let displayName = category
  .replace(/-/g, ' ')
  .replace(/\b\w/g, (c) => c.toUpperCase());

for (const b of businesses) {
  const catSlug = slugify(b.data.category);
  const subSlug = b.data.subCategory ? slugify(b.data.subCategory) : null;

  if (catSlug === category || subSlug === category) {
    matches.push(b);
    if (catSlug === category) displayName = b.data.category;
    else if (subSlug === category && b.data.subCategory) displayName = b.data.subCategory;
  }
}

const pageTitle = `${displayName} — Skiathos Atletico Sponsors`;
const metaDescription =
  `Browse ${matches.length} ${displayName.toLowerCase()} ` +
  `${matches.length === 1 ? 'business' : 'businesses'} in Skiathos. ` +
  `Official sponsors of the Skiathos Atletico football team.`;
const canonicalUrl = `/category/${category}/`;

const siteUrl = "https://skiathos-atletico.gr";

const collectionPageLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "name": `${displayName} in Skiathos`,
      "description": metaDescription,
      "url": `${siteUrl}${canonicalUrl}`,
      "about": {
        "@type": "Thing",
        "name": displayName,
      },
      "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": matches.length,
        "itemListElement": matches.map((b, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "name": b.data.name,
          "url": `${siteUrl}/${b.data.slug}/`,
        })),
      },
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": siteUrl,
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": displayName,
          "item": `${siteUrl}${canonicalUrl}`,
        },
      ],
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={metaDescription}
  canonicalUrl={canonicalUrl}
  structuredData={[collectionPageLd]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-10 lg:py-14">
    <!-- Back -->
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-[#171795] transition-colors duration-200 mb-5 sm:mb-6 group py-2 -ml-2 px-2 rounded-lg hover:bg-slate-50"
    >
      <svg class="w-4 h-4 transition-transform duration-200 group-hover:-translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to directory
    </a>

    <!-- Header -->
    <div class="mb-8 sm:mb-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#171795]/5 border border-[#171795]/10 mb-3 sm:mb-4">
        <span class="w-1.5 h-1.5 rounded-full bg-[#171795]"></span>
        <span class="text-xs font-semibold text-[#171795] uppercase tracking-wider">Category</span>
      </div>
      <h1 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-slate-900 tracking-tight mb-3">
        {displayName}
      </h1>
      <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3">
        <span class="text-sm font-medium text-slate-500 bg-slate-50 px-3 py-1 rounded-full border border-slate-100 w-fit">
          {matches.length} {matches.length === 1 ? 'sponsor' : 'sponsors'}
        </span>
        <p class="text-slate-500 text-sm max-w-lg">
          {metaDescription}
        </p>
      </div>
    </div>

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-[#171795] transition-colors">Home</a>
      <span>/</span>
      <span class="text-slate-700 font-medium">{displayName}</span>
    </nav>

    {
      matches.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-slate-500 text-lg">No businesses found in this category.</p>
          <a href="/" class="mt-4 inline-flex items-center gap-2 text-[#171795] font-semibold text-sm hover:underline">
            Browse all sponsors
          </a>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6 lg:gap-8">
          {matches.map((business) => (
            <BusinessCard business={business} />
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
